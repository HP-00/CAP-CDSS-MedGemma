%%{ init: { "theme": "base", "themeVariables": { "fontSize": "13px" } } }%%
flowchart LR
    case_data["Case Data"]

    case_data --> dispatch["Dispatcher<br/>asyncio.gather"]

    dispatch --> fhir_check{"FHIR<br/>bundle?"}
    dispatch --> lab_check{"lab_report?"}
    dispatch --> cxr_check{"image_path?"}

    subgraph ehr_branch ["EHR Branch"]
        direction TB
        fhir_check -- "yes" --> real_ehr["Real EHR QA<br/>3 GPU calls<br/>(1000 + 1000 + 2000 tok)"]
        fhir_check -. "no" .-> mock_ehr["Mock EHR<br/>0 GPU calls"]
    end

    subgraph lab_branch ["Lab Branch"]
        direction TB
        lab_check -- "yes" --> real_lab["Real Lab<br/>2 GPU calls<br/>(1000 + 3500 tok)"]
        lab_check -. "no" .-> mock_lab["Mock Lab<br/>0 GPU calls"]
    end

    subgraph cxr_branch ["CXR Branch"]
        direction TB
        cxr_check -- "yes" --> real_cxr["Real CXR<br/>1-3 GPU calls<br/>(2000 + 1000 + 1200 tok)"]
        cxr_check -. "no" .-> mock_cxr["Mock CXR<br/>0 GPU calls"]
    end

    real_ehr --> accumulate
    mock_ehr --> accumulate
    real_lab --> accumulate
    mock_lab --> accumulate
    real_cxr --> accumulate
    mock_cxr --> accumulate

    accumulate["Result Accumulation<br/>ToolResult[]"]

    accumulate --> fallback_fill

    fallback_fill["Fallback Fill<br/>Patch incomplete fields"]

    fallback_fill --> state_out["CAPAgentState<br/>clinical_findings, lab_findings,<br/>cxr_findings, curb65_variables,<br/>lab_values, cxr_analysis"]

    classDef gpuNode fill:#3b82f6,stroke:#1e40af,color:#ffffff,stroke-width:2px
    classDef cpuNode fill:#10b981,stroke:#047857,color:#ffffff,stroke-width:2px
    classDef condNode fill:#f59e0b,stroke:#b45309,color:#ffffff,stroke-width:2px
    classDef sourceNode fill:#e5e7eb,stroke:#6b7280,color:#1f2937,stroke-width:2px
    classDef fallbackNode fill:#fef2f2,stroke:#ef4444,color:#991b1b,stroke-width:2px,stroke-dasharray:5 5

    class dispatch,accumulate cpuNode
    class fhir_check,lab_check,cxr_check condNode
    class real_ehr,real_lab,real_cxr gpuNode
    class mock_ehr,mock_lab,mock_cxr fallbackNode
    class fallback_fill fallbackNode
    class case_data,state_out sourceNode

    style ehr_branch fill:#f8fafc,stroke:#94a3b8,stroke-width:1px,color:#334155
    style lab_branch fill:#f8fafc,stroke:#94a3b8,stroke-width:1px,color:#334155
    style cxr_branch fill:#f8fafc,stroke:#94a3b8,stroke-width:1px,color:#334155
