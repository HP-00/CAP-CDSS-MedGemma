%%{ init: { "theme": "base", "themeVariables": { "fontSize": "14px" } } }%%
flowchart LR
    START(( )) --> load_case

    load_case["Load Case"]

    load_case --> parallel_extraction

    subgraph parallel_extraction ["Parallel Extraction"]
        direction TB
        ehr["EHR QA<br/>(3 GPU calls)"]
        lab["Lab Analysis<br/>(2 GPU calls)"]
        cxr["CXR Analysis<br/>(1-3 GPU calls)"]
    end

    parallel_extraction --> severity_scoring["Severity Scoring<br/>CURB-65"]

    severity_scoring --> check_contradictions["Check<br/>Contradictions<br/>CR-1 to CR-11"]

    check_contradictions --> route{"Contradictions<br/>detected?"}

    route -- "contradictions found" --> contradiction_resolution["Contradiction<br/>Resolution<br/>Strategies A-E"]
    route -- "no contradictions" --> treatment_selection

    contradiction_resolution --> treatment_selection["Treatment<br/>Selection<br/>Antibiotics"]

    treatment_selection --> monitoring_plan["Monitoring<br/>Plan"]

    monitoring_plan --> output_assembly["Output<br/>Assembly<br/>Clinician Summary"]

    output_assembly --> END_node([END])

    classDef gpuNode fill:#3b82f6,stroke:#1e40af,color:#ffffff,stroke-width:2px
    classDef cpuNode fill:#10b981,stroke:#047857,color:#ffffff,stroke-width:2px
    classDef condNode fill:#f59e0b,stroke:#b45309,color:#ffffff,stroke-width:2px
    classDef endNode fill:#6b7280,stroke:#374151,color:#ffffff,stroke-width:2px
    classDef startNode fill:#374151,stroke:#111827,color:#ffffff
    classDef extractionTool fill:#60a5fa,stroke:#2563eb,color:#ffffff,stroke-width:1px

    class load_case,severity_scoring,check_contradictions,treatment_selection,monitoring_plan cpuNode
    class parallel_extraction,contradiction_resolution,output_assembly gpuNode
    class route condNode
    class END_node endNode
    class START startNode
    class ehr,lab,cxr extractionTool

    style parallel_extraction fill:#dbeafe,stroke:#3b82f6,stroke-width:2px,color:#1e3a5f
