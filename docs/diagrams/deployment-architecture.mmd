%%{ init: { "theme": "base", "themeVariables": { "fontSize": "13px" } } }%%
flowchart LR
    subgraph source ["Source Code"]
        direction TB
        fe_src["frontend/<br/>React 19 + TypeScript 5.9"]
        py_src["src/ + server/<br/>Python 3.11"]
    end

    subgraph docker ["Docker Multi-Stage Build"]
        direction TB
        subgraph stage1 ["Stage 1: node:22-slim"]
            direction TB
            npm["npm ci → npm run build<br/>→ frontend/dist/"]
        end
        subgraph stage2 ["Stage 2: nvidia/cuda:12.4.0-runtime"]
            direction TB
            pip["Python 3.11<br/>PyTorch (CUDA 12.4)<br/>pip install cap_agent[server]"]
            copy["COPY --from=stage1<br/>dist/ → server/static/"]
            pip --> copy
        end
        stage1 -- "static assets" --> stage2
    end

    fe_src --> stage1
    py_src --> stage2

    subgraph cloudrun ["Google Cloud Run"]
        direction TB
        subgraph infra ["Infrastructure"]
            direction TB
            l4["NVIDIA L4 GPU<br/>24 GB VRAM"]
            specs["8 vCPU · 32 GiB RAM<br/>Concurrency: 1<br/>Min: 0 · Max: 1"]
        end
        subgraph runtime ["Container Runtime"]
            direction TB
            uvicorn["uvicorn --workers 1<br/>--port 8080"]
            api["/api/* → FastAPI<br/>REST + SSE"]
            spa["/* → StaticFiles<br/>Vite SPA"]
            medgemma["MedGemma 4B<br/>lazy singleton<br/>~8 GB bfloat16"]
            uvicorn --> api --> medgemma
            uvicorn --> spa
        end
        subgraph env ["Environment"]
            direction TB
            hf["HF_TOKEN<br/>(gated model)"]
            header["X-Accel-Buffering: no<br/>(SSE passthrough)"]
        end
    end

    docker -- "gcloud builds submit<br/>→ Artifact Registry" --> cloudrun

    client["Browser"] -- "HTTPS" --> cloudrun

